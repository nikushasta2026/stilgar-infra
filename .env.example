# =============================================================================
# Stilgar Infrastructure — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate secrets:
#   openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# CADDY — Reverse Proxy + Automatic SSL
# -----------------------------------------------------------------------------

# Your root domain — subdomains are auto-created per service
# Example: stilgar.io → crm.stilgar.io, paperclip.stilgar.io, etc.
CADDY_DOMAIN=shasta-collective.com

# Email for Let's Encrypt certificate registration (required for SSL)
CADDY_EMAIL=marcus@korblockventures.com

# -----------------------------------------------------------------------------
# SHARED — used by multiple services
# -----------------------------------------------------------------------------

# Anthropic API key for Claude models (required by Paperclip, NanoClaw CEO, Hermes)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Docker image registry prefix (default: ghcr.io/nikushasta2026)
REGISTRY=ghcr.io/nikushasta2026

# Docker image tag (default: latest)
TAG=latest

# -----------------------------------------------------------------------------
# PAPERCLIP
# -----------------------------------------------------------------------------

# Strong random secret for BetterAuth session signing — GENERATE NEW ONE
# Run: openssl rand -hex 32
BETTER_AUTH_SECRET=REPLACE_WITH_RANDOM_HEX_32

# Public URL for Paperclip (set automatically via CADDY_DOMAIN — override if needed)
# BETTER_AUTH_BASE_URL=https://paperclip.yourdomain.com

# -----------------------------------------------------------------------------
# NANOCLAW CEO
# -----------------------------------------------------------------------------

# OpenClaw agent token for the CEO nanoclaw node
NANOCLAW_CEO_TOKEN=oclaw_REPLACE_WITH_YOUR_TOKEN

# Slack Bot Token for CEO ↔ Board reporting
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_YOUR_SLACK_BOT_TOKEN

# Slack Channel ID where CEO posts board updates (optional)
SLACK_BOARD_CHANNEL=C0REPLACE000

# -----------------------------------------------------------------------------
# HERMES AGENT
# -----------------------------------------------------------------------------

# Model to use with Hermes (format: provider:model-name)
HERMES_MODEL=anthropic:claude-sonnet-4-6

# Hermes server port (internal only — no longer exposed externally)
HERMES_PORT=8080

# -----------------------------------------------------------------------------
# TWENTY CRM
# -----------------------------------------------------------------------------

# PostgreSQL credentials for Twenty
TWENTY_DB_USER=twenty
TWENTY_DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# App secret for Twenty (run: openssl rand -hex 32)
TWENTY_APP_SECRET=REPLACE_WITH_RANDOM_HEX_32

# Twenty public URL (set automatically via CADDY_DOMAIN — override if needed)
# TWENTY_SERVER_URL=https://crm.yourdomain.com

# -----------------------------------------------------------------------------
# DEVELOPERS DB — Luxury RE Developer Outreach Database
# -----------------------------------------------------------------------------

# PostgreSQL credentials for the developers database
DEVELOPERS_DB_USER=developers
DEVELOPERS_DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# -----------------------------------------------------------------------------
# HULY CRM — Open-source Business Operations Platform
# For developer outreach, kanban boards, and deal management
# -----------------------------------------------------------------------------

# MongoDB credentials for Huly
HULY_MONGO_USER=huly
HULY_MONGO_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# MinIO S3 credentials for Huly file storage
HULY_MINIO_USER=minioadmin
HULY_MINIO_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
