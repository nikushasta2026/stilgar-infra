# =============================================================================
# Stilgar Infrastructure — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate secrets:
#   openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED — used by multiple services
# -----------------------------------------------------------------------------

# Anthropic API key for Claude models (required by Paperclip, NanoClaw CEO, Hermes)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Docker image registry prefix (default: ghcr.io/nikushasta2026)
REGISTRY=ghcr.io/nikushasta2026

# Docker image tag (default: latest)
TAG=latest

# -----------------------------------------------------------------------------
# PAPERCLIP
# -----------------------------------------------------------------------------

# Strong random secret for BetterAuth session signing — GENERATE NEW ONE
# Run: openssl rand -hex 32
BETTER_AUTH_SECRET=REPLACE_WITH_RANDOM_HEX_32

# Public URL for Paperclip (how users reach it — set to your domain)
PAPERCLIP_URL=https://paperclip.yourdomain.com

# Internal URL for nanoclaw-ceo to reach Paperclip (docker internal)
# Leave as-is unless you rename the service
PAPERCLIP_GATEWAY_URL=http://paperclip:3100

# -----------------------------------------------------------------------------
# NANOCLAW CEO
# -----------------------------------------------------------------------------

# OpenClaw agent token for the CEO nanoclaw node
# Obtain from your OpenClaw gateway admin panel
NANOCLAW_CEO_TOKEN=oclaw_REPLACE_WITH_YOUR_TOKEN

# Slack Bot Token for CEO ↔ Board reporting
# Obtain from https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_YOUR_SLACK_BOT_TOKEN

# Slack Channel ID where CEO posts board updates (optional)
SLACK_BOARD_CHANNEL=C0REPLACE000

# -----------------------------------------------------------------------------
# HERMES AGENT
# -----------------------------------------------------------------------------

# Model to use with Hermes (format: provider:model-name)
# Examples:
#   anthropic:claude-sonnet-4-6
#   openai:gpt-4o
#   openrouter:anthropic/claude-3.7-sonnet
HERMES_MODEL=anthropic:claude-sonnet-4-6

# OpenRouter API key (alternative to Anthropic key for Hermes)
# Obtain from https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# Hermes server port (default: 8080)
HERMES_PORT=8080

# -----------------------------------------------------------------------------
# COOLIFY (optional, managed by Coolify itself)
# -----------------------------------------------------------------------------
# These are set by Coolify in its environment — listed here for documentation.
# COOLIFY_APP_ID=your-coolify-app-id
# COOLIFY_FQDN=your.domain.com
